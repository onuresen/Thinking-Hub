{
  "name": "Thinking Hub",
  "short_name": "Thinking Hub",
  "description": "Multi-tool personal thinking & productivity platform — projects, decisions, schedule, dependency graph, journal and more. Local-first, works offline.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0b0b0d",
  "theme_color": "#0b0b0d",
  "icons": [
    { "src": "icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "icons/icon-512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "icons/icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "share_target": {
    "action": "./capture-hub.html",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "shortcuts": [
    { "name": "Capture", "short_name": "Capture", "url": "./capture-hub.html", "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }] },
    { "name": "Journal", "short_name": "Journal", "url": "./journal-hub.html", "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }] },
    { "name": "Today", "short_name": "Today", "url": "./index.html", "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }] }
  ]
}
